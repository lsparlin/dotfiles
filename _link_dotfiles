#!/bin/zsh
autoload colors; colors

DRY_RUN=true
if [ "$1" = "live" ]; then
  DRY_RUN=false
fi

DOTFILES_DIR=$(realpath "$(dirname "$0")")

# Root files to link as ~/.filename — explicit exclusions anchored to filename start
function list_linkable_dotfiles {
  ls -1 "$DOTFILES_DIR" \
    | grep -vE '^(README\.md|CLAUDE\.md|docs|scripts|tpm|_configuration|_link_dotfiles|\..*)'
}

# Link source → dest; prints intent in dry-run, executes in live mode
link() {
  if $DRY_RUN; then
    echo "Would link $fg_bold[green]$2$reset_color -> $fg[blue]$1$reset_color"
  else
    ln -fvhsn "$1" "$2"
  fi
}

if $DRY_RUN; then
  echo "$fg_bold[green]DRY RUN$reset_color"
  echo "_______"
fi

# Root dotfiles → ~/.filename
if $DRY_RUN; then
  list_linkable_dotfiles \
    | xargs -I% echo "Would link $fg_bold[green]~/.%$reset_color -> $fg[blue]$DOTFILES_DIR/%$reset_color"
else
  list_linkable_dotfiles | xargs -I% ln -fvhs "$DOTFILES_DIR/%" "$HOME/.%"
fi

# App configs → ~/.config/<name> (implicit: every dir in _configuration/ except fish)
# fish is linked per-file because ~/.config/fish/ is a living directory that
# Fish and Fisher write into (conf.d/, functions/, completions/, fish_variables)
ls -1 "$DOTFILES_DIR/_configuration" \
  | grep -v '^fish$' \
  | while read dir; do
      link "$DOTFILES_DIR/_configuration/$dir" "$HOME/.config/$dir"
    done

# Fish: explicit per-file links
link "$DOTFILES_DIR/_configuration/fish/config.fish"     "$HOME/.config/fish/config.fish"
link "$DOTFILES_DIR/_configuration/fish/fish_plugins"    "$HOME/.config/fish/fish_plugins"
ls -1 "$DOTFILES_DIR/_configuration/fish/aliases" \
  | while read fn; do
      link "$DOTFILES_DIR/_configuration/fish/aliases/$fn" "$HOME/.config/fish/functions/$fn"
    done

if $DRY_RUN; then echo "_______"; fi
